# Discord webhook to post notifications to (required)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy

# Polling interval in seconds (default 300 = 5 minutes)
POLL_INTERVAL_SECONDS=300

# HTTP settings
REQUEST_TIMEOUT=20
MAX_RETRIES=3
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0 Safari/537.36

# Where to persist the "already notified" URL list.
# On Render, attach a Disk and point this at its mount path, e.g. /var/data/seen.json
STORAGE_PATH=seen.json

# If true, the first run silently seeds the store instead of spamming
# Discord with the entire current backlog of listings.
SEED_ON_FIRST_RUN=true
